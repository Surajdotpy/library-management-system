# ================================
# APPLICATION
# ================================
NODE_ENV=development
PORT=5000
FRONTEND_URL=http://localhost:3000

# ================================
# DATABASE CONFIGURATION
# ================================
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=library_management
DATABASE_USER=postgres
DATABASE_PASSWORD=your_database_password_here

# ================================
# AUTHENTICATION
# ================================
JWT_SECRET=replace_with_a_long_random_secret
JWT_EXPIRES_IN=7d

# ================================
# DEFAULT ADMIN CREDENTIALS
# ================================
# These are used by scripts in scripts/ for first-time setup only.

DEFAULT_SUPERADMIN_EMAIL=superadmin@yourlibrary.com
DEFAULT_SUPERADMIN_PASSWORD=change_me_admin123

DEFAULT_ADMIN1_EMAIL=admin1@yourlibrary.com
DEFAULT_ADMIN1_PASSWORD=change_me_admin123

DEFAULT_ADMIN2_EMAIL=admin2@yourlibrary.com
DEFAULT_ADMIN2_PASSWORD=change_me_admin123

DEFAULT_ADMIN3_EMAIL=admin3@yourlibrary.com
DEFAULT_ADMIN3_PASSWORD=change_me_admin123

DEFAULT_ADMIN4_EMAIL=admin4@yourlibrary.com
DEFAULT_ADMIN4_PASSWORD=change_me_admin123

# ================================
# IMPORTANT SECURITY NOTES
# ================================
# 1. Copy this file to .env and fill in real values.
# 2. NEVER commit .env to GitHub.
# 3. Change seeded passwords immediately after first login.
# 4. Use strong secrets and production database credentials.
