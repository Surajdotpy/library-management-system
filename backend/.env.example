# ================================
# APPLICATION
# ================================
NODE_ENV=development
PORT=5000
FRONTEND_URL=http://localhost:3000

# ================================
# DATABASE CONFIGURATION
# ================================
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=library_management
DATABASE_USER=postgres
DATABASE_PASSWORD=your_database_password_here
DATABASE_SSL=false
# Set to true only if you explicitly accept self-signed certificates in production.
DATABASE_SSL_ALLOW_SELF_SIGNED=false
# Optional absolute path to a CA certificate bundle for managed Postgres providers.
DATABASE_SSL_CA_PATH=

# ================================
# AUTHENTICATION
# ================================
JWT_SECRET=replace_with_a_long_random_secret
JWT_EXPIRES_IN=7d
PAYMENT_WEBHOOK_SECRET=replace_with_a_webhook_secret_for_verified_payments
PAYMENT_PUBLIC_LINK_SECRET=replace_with_a_different_long_random_secret
PAYMENT_PUBLIC_LINK_EXPIRES_IN=48h
PUBLIC_APP_URL=http://localhost:3000

# ================================
# CASHFREE PAYMENT GATEWAY
# ================================
# Keep CASHFREE_MODE=mock until your real Cashfree account is ready.
CASHFREE_MODE=mock
CASHFREE_APP_ID=dummy_cashfree_app_id
CASHFREE_SECRET_KEY=dummy_cashfree_secret_key
# Optional: if empty, webhook verification falls back to CASHFREE_SECRET_KEY.
CASHFREE_WEBHOOK_SECRET=dummy_cashfree_webhook_secret
CASHFREE_API_VERSION=2025-01-01
CASHFREE_WEBHOOK_MAX_AGE_SECONDS=300

# ================================
# DEFAULT ADMIN CREDENTIALS
# ================================
# These are used by scripts in scripts/ for first-time setup only.

DEFAULT_SUPERADMIN_EMAIL=superadmin@yourlibrary.com
DEFAULT_SUPERADMIN_PASSWORD=change_me_to_a_long_random_superadmin_password

DEFAULT_ADMIN1_EMAIL=admin1@yourlibrary.com
DEFAULT_ADMIN1_PASSWORD=change_me_to_a_long_random_admin1_password

DEFAULT_ADMIN2_EMAIL=admin2@yourlibrary.com
DEFAULT_ADMIN2_PASSWORD=change_me_to_a_long_random_admin2_password

DEFAULT_ADMIN3_EMAIL=admin3@yourlibrary.com
DEFAULT_ADMIN3_PASSWORD=change_me_to_a_long_random_admin3_password

DEFAULT_ADMIN4_EMAIL=admin4@yourlibrary.com
DEFAULT_ADMIN4_PASSWORD=change_me_to_a_long_random_admin4_password

# ================================
# IMPORTANT SECURITY NOTES
# ================================
# 1. Copy this file to .env and fill in real values.
# 2. NEVER commit .env to GitHub.
# 3. Change seeded passwords immediately after first login.
# 4. Use strong secrets and production database credentials.
