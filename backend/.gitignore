# ================================
# Dependencies
# ================================
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
package-lock.json

# ================================
# Build Outputs
# ================================
dist/
build/
*.tsbuildinfo

# ================================
# TypeScript Generated Files
# ================================
# We write TypeScript (.ts), these are auto-generated
*.js
*.js.map
*.d.ts
*.d.ts.map
FULL.ts
FULL.d.ts.map

# ================================
# Environment Files (SECRETS!)
# ================================
# Contains passwords and API keys
.env
.env.local
.env.test
.env.production

# Keep example file for reference
!.env.example

# ================================
# Test Files
# ================================
# Not needed in production
*.test.ts
*.test.tsx
*.spec.ts
*.spec.tsx
__tests__/
tests/
coverage/

# ================================
# IDE & Editor Files
# ================================
# Personal settings, not shared
.vscode/
.idea/
*.sublime-*
*.suo
*.ntvs*
*.njsproj*
*.sln
*.sw?

# ================================
# Operating System Files
# ================================
.DS_Store
Thumbs.db
desktop.ini

# ================================
# Logs
# ================================
*.log
logs/

# ================================
# Temporary Files
# ================================
*.tmp
*.temp
*.bak
*.swp
*~
.cache/

# ================================
# Documentation (Local Planning)
# ================================
docs/
packages/

